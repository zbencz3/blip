# ============================================================
# blip-server environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- APNs (Apple Push Notification service) ----------------

# Your APNs Auth Key (.p8 file contents, PEM-encoded)
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 10-character Key ID from Apple Developer portal
APNS_KEY_ID=XXXXXXXXXX

# 10-character Team ID from Apple Developer portal
APNS_TEAM_ID=XXXXXXXXXX

# APNs topic (your app's bundle identifier)
APNS_TOPIC=com.yourname.blip

# ---- Vapor / server ----------------------------------------

# LOG_LEVEL: trace | debug | info | notice | warning | error | critical
LOG_LEVEL=info

# Set to "production" on Fly.io, "development" locally
APP_ENV=development
